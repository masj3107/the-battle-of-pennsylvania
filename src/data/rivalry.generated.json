  "timeline": [
    {
      "id": "tl-1",
      "year": "1967",
      "title": "Pennsylvania gets its second front.",
      "body": "Philadelphia entered the league in the expansion era. Pittsburgh was already in place. Geography did the easy part. Identity did the rest.",
      "type": "era",
      "teamLean": "neutral"
    },
    {
      "id": "tl-2",
      "year": "1970s",
      "title": "The early shape of hostility arrives fast.",
      "body": "Philadelphia built its reputation on force, presence, and volume. Pittsburgh answered with speed and elite skill. The contrast made the rivalry legible immediately.",
      "type": "era",
      "teamLean": "neutral"
    },
    {
      "id": "tl-3",
      "year": "1989",
      "title": "Hextall turns the crease into an argument.",
      "body": "Ron Hextall brought volatility into every Flyers-Penguins night. The position stopped being neutral. It became part of the theatre.",
      "type": "player",
      "teamLean": "flyers"
    },
    {
      "id": "tl-4",
      "year": "1990s",
      "title": "Lemieux and Jagr drag the skill ceiling upward.",
      "body": "Pittsburgh's stars turned rivalry games into technical punishments as often as emotional ones. Defensive mistakes did not survive them.",
      "type": "player",
      "teamLean": "penguins"
    },
    {
      "id": "tl-5",
      "year": "2000s",
      "title": "The rivalry pauses, then comes back sharper.",
      "body": "There were stretches where the matchup cooled in the standings but never in memory. It only needed a postseason trigger.",
      "type": "era",
      "teamLean": "neutral"
    },
    {
      "id": "tl-6",
      "year": "2012",
      "title": "The series that felt like controlled demolition.",
      "body": "Six games. Fifty-six goals. The state line vanished under pure offensive chaos. Every period felt one mistake away from public disorder.",
      "type": "playoff",
      "teamLean": "neutral"
    },
    {
      "id": "tl-7",
      "year": "2010s",
      "title": "Crosby and Giroux give the rivalry its modern faces.",
      "body": "Both captains carried the emotional burden differently, but the effect was the same. Meetings stopped feeling routine the moment the stars were in frame.",
      "type": "player",
      "teamLean": "neutral"
    },
    {
      "id": "tl-8",
      "year": "Now",
      "title": "The temperature remains banked, not gone.",
      "body": "The rivalry no longer needs every season to be a peak season. It survives on memory, regional contempt, and the certainty that one clean hit can bring the whole archive back.",
      "type": "controversy",
      "teamLean": "neutral"
    }
  ]
}
